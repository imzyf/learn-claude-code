# s11 错误恢复的可选环境变量。
# 想启用时把需要的行复制到仓库根目录的 .env（pnpm dev 会自动加载）：
#   cp s11_error_recovery/defaults.env .env
# 或命令行内联，只对一次运行生效：
#   S11_FALLBACK_MODEL_ID=claude-opus-4-1 pnpm dev s11_error_recovery/main.ts

# 连续 3 次 529（过载）后切换到的备用模型 id。
# 不设：一直用主模型（MODEL_ID）重试，不切换（withRetry 会打日志说明未配置）。
S11_FALLBACK_MODEL_ID=claude-opus-4-1

# 首次撞 max_tokens 时把 8K 升级到的上限。
# 不设：默认 64000。
S11_ESCALATED_MAX_TOKENS=64000

# 每次请求的初始 max_tokens。
# 不设：默认 8000。
S11_DEFAULT_MAX_TOKENS=8000
