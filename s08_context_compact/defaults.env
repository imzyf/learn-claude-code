# s08 压缩流水线的五个阈值（默认值）。
# 想覆盖时把需要的行复制到仓库根目录的 .env（pnpm dev 会自动加载）：
#   cp s08_context_compact/defaults.env .env
# 或命令行内联，只对一次运行生效：
#   COMPACT_SNIP_MAX_MESSAGES=6 pnpm dev s08_context_compact/main.ts

# L1 裁剪阈值：消息数超过它就裁掉中间部分
COMPACT_SNIP_MAX_MESSAGES=50
# L2 保留最近 N 条工具结果不动（最后一条消息整条不压），只压缩更早的
COMPACT_KEEP_RECENT=3
# L3 预算：最新一轮 tool_result 总量超过它才开始落盘
COMPACT_TOOL_RESULT_BUDGET=200000
# L3 落盘阈值：单条工具结果超过该长度才值得写到磁盘
COMPACT_PERSIST_THRESHOLD=30000
# L4 触发阈值：估算大小（JSON 字符数，不是 token）超过它就做 LLM 摘要
COMPACT_CONTEXT_LIMIT=50000
